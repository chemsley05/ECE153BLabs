#include "EXTI.h"
#include "LED.h"

void EXTI_Init(void) {
// Initialize User Button PC13
// Enable GPIOC clock for user button
RCC->AHB2ENR |= RCC_AHB2ENR_GPIOCEN;

// Set PC13 as input mode
GPIOC->MODER &= ~(GPIO_MODER_MODE13);

// No pull-up no pull-down
GPIOC->PUPDR &= ~(GPIO_PUPDR_PUPD13);

// Configure SYSCFG EXTI

// Enable SYSCFG clock
RCC->APB2ENR |= RCC_APB2ENR_SYSCFGEN;

// Map EXTI13 to C
// EXTI13 is in EXTICR[3], bits [7:4]
SYSCFG->EXTICR[3] &= ~(SYSCFG_EXTICR4_EXTI13);
SYSCFG->EXTICR[3] |= SYSCFG_EXTICR4_EXTI13_PC;

// Configure EXTI Trigger

// Disable rising edge trigger for line 13
EXTI->RTSR1 &= ~(EXTI_RTSR1_RT13);

// Enable falling edge trigger for line 13
EXTI->FTSR1 |= EXTI_FTSR1_FT13;


// Enable EXTI

// Unmask interrupt for EXTI13
EXTI->IMR1 |= EXTI_IMR1_IM13;


// Configure and Enable in NVIC


NVIC_EnableIRQ(EXTI15_10_IRQn);
NVIC_SetPriority(EXTI15_10_IRQn, 0);
}

// Interrupt handler for EXTI lines 10 through 15
void EXTI15_10_IRQHandler(void) {
// EXTI13 caused the interrupt
if ((EXTI->PR1 & EXTI_PR1_PIF13) == EXTI_PR1_PIF13) {

	// Clear interrupt pending bit by  1
	EXTI->PR1 |= EXTI_PR1_PIF13;
	
	// Toggle green LED
	Green_LED_Toggle();
}
}

