		GPIOA->ODR |= GPIO_ODR_OD6;
		for(int i = 0; i < DELAY; i++){}
			
		// Step 4: PA6 and PA8 ON
		GPIOA->ODR &= ~(GPIO_ODR_OD5 | GPIO_ODR_OD6 | GPIO_ODR_OD8 | GPIO_ODR_OD9);
		GPIOA->ODR |= (GPIO_ODR_OD6 | GPIO_ODR_OD8);
		for(int i = 0; i < DELAY; i++){}
			
		// Step 5: only PA8 ON
		GPIOA->ODR &= ~(GPIO_ODR_OD5 | GPIO_ODR_OD6 | GPIO_ODR_OD8 | GPIO_ODR_OD9);
		GPIOA->ODR |= GPIO_ODR_OD8;
		for(int i = 0; i < DELAY; i++){}
			
		// Step 6: PA8 and PA9 ON
		GPIOA->ODR &= ~(GPIO_ODR_OD5 | GPIO_ODR_OD6 | GPIO_ODR_OD8 | GPIO_ODR_OD9);
		GPIOA->ODR |= (GPIO_ODR_OD8 | GPIO_ODR_OD9);
		for(int i = 0; i < DELAY; i++){}
			
		// Step 7: only PA9 ON
		GPIOA->ODR &= ~(GPIO_ODR_OD5 | GPIO_ODR_OD6 | GPIO_ODR_OD8 | GPIO_ODR_OD9);
		GPIOA->ODR |= GPIO_ODR_OD9;
		for(int i = 0; i < DELAY; i++){}
			
		// Step 8: PA9 and PA5 ON
		GPIOA->ODR &= ~(GPIO_ODR_OD5 | GPIO_ODR_OD6 | GPIO_ODR_OD8 | GPIO_ODR_OD9);
		GPIOA->ODR |= (GPIO_ODR_OD9 | GPIO_ODR_OD5);
