void RTC_Alarm_Enable(void) {
EXTI->RTSR1 |= EXTI_RTSR1_RT18;
EXTI->IMR1 |= EXTI_IMR1_IM18;
EXTI->EMR1 |= EXTI_EMR1_EM18;
EXTI->PR1 |= EXTI_PR1_PIF18;

NVIC_EnableIRQ(RTC_Alarm_IRQn);
NVIC_SetPriority(RTC_Alarm_IRQn, 0);
}

void RTC_Set_AlarmA_Second30(void) {
RTC_Disable_Write_Protection();

RTC->CR &= ~RTC_CR_ALRAE;
RTC->CR &= ~RTC_CR_ALRAIE;

while((RTC->ISR & RTC_ISR_ALRAWF) == 0);

RTC->ALRMAR =
	RTC_ALRMAR_MSK4 |
	RTC_ALRMAR_MSK3 |
	RTC_ALRMAR_MSK2 |
	(3U << 4) |
	(0U);

RTC->ISR &= ~RTC_ISR_ALRAF;

RTC->CR |= RTC_CR_ALRAIE;
RTC->CR |= RTC_CR_ALRAE;

RTC_Enable_Write_Protection();
}

void RTC_Set_AlarmB_EverySecond(void) {
RTC_Disable_Write_Protection();

RTC->CR &= ~RTC_CR_ALRBE;
RTC->CR &= ~RTC_CR_ALRBIE;

while((RTC->ISR & RTC_ISR_ALRBWF) == 0);

RTC->ALRMBR =
	RTC_ALRMBR_MSK4 |
	RTC_ALRMBR_MSK3 |
	RTC_ALRMBR_MSK2 |
	RTC_ALRMBR_MSK1;

RTC->ISR &= ~RTC_ISR_ALRBF;

RTC->CR |= RTC_CR_ALRBIE;
RTC->CR |= RTC_CR_ALRBE;

RTC_Enable_Write_Protection();
}

void RTC_Alarm_IRQHandler(void) {
if((RTC->ISR & RTC_ISR_ALRAF) != 0) {
RTC->ISR &= ~RTC_ISR_ALRAF;
EXTI->PR1 |= EXTI_PR1_PIF18;
Green_LED_Toggle();
}

if((RTC->ISR & RTC_ISR_ALRBF) != 0) {
	RTC->ISR &= ~RTC_ISR_ALRBF;
	EXTI->PR1 |= EXTI_PR1_PIF18;
	Green_LED_Toggle();
}
}

